# Copy to .env and source it before booting services.
# Defaults to MockModel — no creds needed to run the demo.

# Provider: mock | openai | anthropic
TULIP_MODEL_PROVIDER=mock

# OpenAI (when TULIP_MODEL_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# TULIP_MODEL_ID=gpt-4o

# Anthropic (when TULIP_MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# TULIP_MODEL_ID=claude-sonnet-4-6

# Service ports (defaults shown)
RESEARCH_PORT=8001
FINANCE_PORT=8002
