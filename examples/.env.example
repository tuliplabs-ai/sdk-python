# Tulip notebook configuration. Copy to .env and edit.
#
# Tulip defaults to the bundled mock model when no provider is set, so
# notebooks run end-to-end with no credentials. Set TULIP_MODEL_PROVIDER
# (and the matching credentials) when you want a live model.

# Model provider: "mock" (default), "openai", or "anthropic".
# TULIP_MODEL_PROVIDER=mock

# ─── Mock (offline, no credentials) ─────────────────────────────────
# Force the bundled mock model — useful in CI or air-gapped runs.
# TULIP_MODEL_PROVIDER=mock

# ─── OpenAI ─────────────────────────────────────────────────────────
# TULIP_MODEL_PROVIDER=openai
# TULIP_MODEL_ID=gpt-4o
# OPENAI_API_KEY=sk-...

# ─── Anthropic ──────────────────────────────────────────────────────
# TULIP_MODEL_PROVIDER=anthropic
# TULIP_MODEL_ID=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Vendor integrations (examples/integrations/) ───────────────────
# Each is optional: set the credential to hit the live API, leave it
# unset to get a deterministic offline sample. See
# examples/integrations/README.md.

# Threat intel (VirusTotal-shaped) — IOC reputation/enrichment.
# VT_API_KEY=...

# SIEM (Splunk/Elastic-shaped) — log/alert search.
# SIEM_URL=https://siem.example.net
# SIEM_TOKEN=...

# GPU clouds — inference-fingerprint timing-probe dispatch.
# RUNPOD_API_KEY=...
# LAMBDA_API_KEY=...
# LAMBDA_REGION=us-east-1
# LAMBDA_PROBE_RESULT_URL=https://results.example.net/probe
